	struct virtio_gpu_response_header responseHeader = *pResponseBuffer;
	pResourceDesc->pBuffer = pBuffer;
	pResourceDesc->bufferSize = bufferSize;
	virtualFree((uint64_t)pCommandBuffer, commandBufferSize);
